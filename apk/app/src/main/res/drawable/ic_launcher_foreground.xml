<?xml version="1.0" encoding="utf-8"?>
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!--
        Design: Bold "C" arc — center (57,54), radius 23
        Opens to the right (gap between terminals at 45° NE and SE).
        Two circular terminals at the open ends → visually a connector/converter symbol.
        Visual center of mass: x ≈ 54 (centered in viewport).

        Arc path breakdown:
          M73,38  → start at NE terminal (57 + 23·cos45°, 54 − 23·sin45°)
          A23,23 0 1 0 73,70  → CCW 270° arc to SE terminal, through W side
    -->

    <!-- Glow halo behind the arc -->
    <path
        android:pathData="M73,38 A23,23 0 1 0 73,70"
        android:strokeColor="#4FC3F7"
        android:strokeAlpha="0.18"
        android:strokeWidth="18"
        android:strokeLineCap="round"
        android:fillColor="#00000000"/>

    <!-- Main C arc -->
    <path
        android:pathData="M73,38 A23,23 0 1 0 73,70"
        android:strokeColor="#4FC3F7"
        android:strokeWidth="8.5"
        android:strokeLineCap="round"
        android:fillColor="#00000000"/>

    <!-- Top terminal circle at (73, 38) r=5.5 -->
    <path
        android:pathData="M67.5,38 A5.5,5.5 0 0 1 78.5,38 A5.5,5.5 0 0 1 67.5,38 Z"
        android:fillColor="#4FC3F7"/>

    <!-- Bottom terminal circle at (73, 70) r=5.5 -->
    <path
        android:pathData="M67.5,70 A5.5,5.5 0 0 1 78.5,70 A5.5,5.5 0 0 1 67.5,70 Z"
        android:fillColor="#4FC3F7"/>

</vector>
